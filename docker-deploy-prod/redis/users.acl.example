user default off
user productservice_read on >change-me ~ProductServiceApp:* +ping +echo +client|getname +client|setname +client|setinfo +get +mget +exists +ttl +pttl +type +scan +strlen
user productservice_write on >change-me ~ProductServiceApp:* +ping +echo +client|getname +client|setname +client|setinfo +get +mget +exists +ttl +pttl +type +scan +strlen +set +setex +psetex +del +unlink +expire +pexpire
user productservice_metrics on >change-me ~* +ping +echo +info +config|get +client|getname +client|setname +client|setinfo
user productservice_admin on >change-me ~* +@all
