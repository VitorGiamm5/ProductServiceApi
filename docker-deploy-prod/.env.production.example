COMPOSE_PROJECT_NAME=productservice-prod

# Public hosts
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
AUTH_DOMAIN=auth.example.com
GRAFANA_DOMAIN=grafana.example.com

# Application
ASPNETCORE_ENVIRONMENT=Production
DOTNET_RUNNING_IN_CONTAINER=true

# PostgreSQL
POSTGRES_DB=dbproducts
POSTGRES_USER=productservice_app
POSTGRES_PASSWORD=change-me
POSTGRES_READ_USER=productservice_read
POSTGRES_READ_PASSWORD=change-me
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=change-me
POSTGRES_KEYCLOAK_DB=keycloak
POSTGRES_KEYCLOAK_USER=keycloak
POSTGRES_KEYCLOAK_PASSWORD=change-me

# Redis
REDIS_READ_USER=productservice_read
REDIS_READ_PASSWORD=change-me
REDIS_WRITE_USER=productservice_write
REDIS_WRITE_PASSWORD=change-me
REDIS_METRICS_USER=productservice_metrics
REDIS_METRICS_PASSWORD=change-me

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_CLIENT_WEB=productservice-dev-blazor
KEYCLOAK_CLIENT_BFF=productservice-bff
KEYCLOAK_CLIENT_BFF_SECRET=change-me

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
