# Default endpoint for the first login flow test.
# Inside docker on Windows, host.docker.internal points to the host machine.
KEYCLOAK_TOKEN_URL=http://host.docker.internal:8081/realms/productservice/protocol/openid-connect/token
KEYCLOAK_CLIENT_ID=productservice-dev-blazor
KEYCLOAK_USERNAME=operator
KEYCLOAK_PASSWORD=operator123
