@inherits LayoutComponentBase
@implements IDisposable
@inject LoadingState Loading
@inject NavigationManager Navigation

<div class="page">
    @if (!IsLoginRoute)
    {
        <div class="sidebar">
            <NavMenu />
        </div>
    }

    <main>
        @if (!IsLoginRoute)
        {
            <div class="top-row px-4">
                <span>Product Service Backoffice</span>
                <LoginDisplay />
            </div>
        }

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@if (Loading.IsLoading)
{
    <div class="loading-veil" role="status" aria-live="polite" aria-label="Carregando">
        <div class="loading-card">
            <span class="loading-ring"></span>
            <span class="loading-text">Carregando</span>
        </div>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool IsLoginRoute => IsCurrentRoute("/") || IsCurrentRoute("/login") || IsCurrentRoute("/logout");

    protected override void OnInitialized()
    {
        Loading.Changed += OnLoadingChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLoadingChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs args)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private bool IsCurrentRoute(string route)
    {
        var currentPath = new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/');
        var routePath = route.TrimEnd('/');

        return string.Equals(currentPath, routePath, StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        Loading.Changed -= OnLoadingChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
