{
  "SystemName": "6137_api_product_service",
  "Service": "Products",
  "AppInfo": {
    "Info": {
      "Title": "Product.Core - Integration API",
      "Description": "API do Sistema Produtos e Pedidos",
      "Version": "0.0.2",
      "TermsOfService": "https://google.com",
      "Contact": {
        "Name": "Product IT",
        "Email": "vitorgiammella@gmail.com",
        "Url": "https://www.linkedin.com/in/vitor-giamm/"
      },
      "License": {
        "Name": "Copyright",
        "Url": ""
      }
    }
  },
  "Kestrel": {
    "Port": 9005
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj} {Properties}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProcessId"
    ],
    "Properties": {
      "Application": "ProductServiceApp",
      "Environment": "Development"
    }
  },
  "ConnectionStrings": {
    "PostgresWrite": "Server=localhost;Port=9000;Database=dbproducts;Username=randandan;Password=randandan_XLR;SSL Mode=Disable;",
    "PostgresRead": "Server=localhost;Port=9001;Database=dbproducts;Username=read_randandan;Password=read_randandan_XLR;SSL Mode=Disable;"
  },
  "DatabaseSettings": {
    "EnableLoadBalancing": true
  },
  "Redis": {
    "ConnectionString": "localhost:6379,user=productservice_write,password=productservice_write_XLR,abortConnect=false,connectTimeout=500,asyncTimeout=100,syncTimeout=100,connectRetry=1",
    "ReadConnectionString": "localhost:6379,user=productservice_read,password=productservice_read_XLR,abortConnect=false,connectTimeout=500,asyncTimeout=100,syncTimeout=100,connectRetry=1",
    "WriteConnectionString": "localhost:6379,user=productservice_write,password=productservice_write_XLR,abortConnect=false,connectTimeout=500,asyncTimeout=100,syncTimeout=100,connectRetry=1",
    "InstanceName": "ProductServiceApp:",
    "MaxCachePayloadBytes": 262144,
    "OperationTimeoutMilliseconds": 100,
    "CircuitBreakerFailureRatio": 0.5,
    "CircuitBreakerMinimumThroughput": 3,
    "CircuitBreakerSamplingSeconds": 30,
    "CircuitBreakerBreakSeconds": 15,
    "ProductsAbsoluteExpirationMinutes": 10,
    "ProductsSlidingExpirationMinutes": 2,
    "OrdersAbsoluteExpirationMinutes": 10,
    "OrdersSlidingExpirationMinutes": 2
  },
  "CacheWarmup": {
    "Enabled": true,
    "RunOnStartup": true,
    "BlockStartupUntilComplete": false,
    "StartupDelaySeconds": 3,
    "TimeoutSeconds": 20,
    "MaxDegreeOfParallelism": 2,
    "Features": {
      "products": {
        "Enabled": true,
        "WarmupAll": true,
        "WarmupById": true,
        "MaxItems": 500
      },
      "orders": {
        "Enabled": true,
        "WarmupAll": true,
        "WarmupById": false,
        "MaxItems": 500
      }
    }
  },
  "WorkersReplicas": {
    "ReplicasCreateProduct": 1,
    "ReplicasUpdateProduct": 1,
    "ReplicasDeleteProduct": 1,
    "ReplicasGetAllProduct": 1,
    "ReplicasGetByIdProduct": 1,
    "ReplicasCreateOrder": 1,
    "ReplicasUpdateOrder": 1,
    "ReplicasDeleteOrder": 1,
    "ReplicasGetAllOrder": 1,
    "ReplicasGetByIdOrder": 1
  },
  "QueueCapacity": {
    "QueueCreateProduct": 100,
    "QueueUpdateProduct": 100,
    "QueueDeleteProduct": 100,
    "QueueCreateOrder": 100,
    "QueueUpdateOrder": 100,
    "QueueDeleteOrder": 100
  },
  "RetryPolicy": {
    "MaxRetryAttempts": 3,
    "DelayBetweenRetriesInSeconds": 2
  },
  "KeepAliveTimeoutSeconds": 30,
  "RequestTimeoutSeconds": 15
}
